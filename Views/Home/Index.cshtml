@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<div class="hero-section">
    <div class="container position-relative" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <img src="~/Images/logo.svg" alt="EventEase Logo" class="hero-logo" />
                <h1 class="hero-title">Venue Booking,<br /><span>Made Simple.</span></h1>
                <p class="hero-subtitle">
                    Manage venues, schedule events, and handle bookings — all from one place.
                    </p>
                <a href="/Bookings/Create" class="hero-btn">+ New Booking</a>
                <a href="/Venues" class="hero-btn-outline">Browse Venues</a>
            </div>
        </div>
    </div>
</div>

<!-- WAVE -->
<div class="wave-divider" style="background: var(--navy);">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg">
      
    </svg>
</div>

<!-- CARDS -->
<div class="cards-section">
    <div class="container">
        <div class="text-center">
            
            <h2 class="section-title">Everything you need to manage bookings</h2>
            <p class="section-sub">Use the tools below to manage the EventEase booking system</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <a href="/Venues" class="action-card">
                    <div class="card-icon icon-navy">🏛️</div>
                    <h4 class="card-title">Venues</h4>
                    <p class="card-desc">Add, update and manage all available venues. Set capacity, location and upload venue images.</p>
                    <span class="card-link">Manage Venues</span>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Events" class="action-card">
                    <div class="card-icon icon-teal">📅</div>
                    <h4 class="card-title">Events</h4>
                    <p class="card-desc">Create and manage events. Assign venues to events or leave them unassigned until a venue is available.</p>
                    <span class="card-link">Manage Events</span>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Bookings" class="action-card">
                    <div class="card-icon icon-coral">🎟️</div>
                    <h4 class="card-title">Bookings</h4>
                    <p class="card-desc">Create and manage customer bookings. The system automatically prevents double bookings.</p>
                    <span class="card-link">Manage Bookings</span>
                </a>
            </div>
        </div>
    </div>
</div>

